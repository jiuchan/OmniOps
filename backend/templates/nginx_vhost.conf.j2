# Nginx Configuration for {{ zone.domain }}
# Auto-generated by LVS Nexus Control (L7 Ansible Engine)

upstream backend_{{ zone.id }} {
{% for upstream in upstreams %}
    server {{ upstream.ip_address }}:{{ upstream.port }} weight={{ upstream.weight }};
{% endfor %}
}

server {
    listen {{ zone.listen_port }};
    server_name {{ zone.domain }};

{% if zone.ssl_enabled == 1 %}
    # SSL 配置预留位
    # ssl_certificate     /etc/nginx/certs/{{ zone.domain }}.crt;
    # ssl_certificate_key /etc/nginx/certs/{{ zone.domain }}.key;
{% endif %}

    # 基础安全与代理请求头透传设定
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # 默认网关路由
    location / {
        proxy_pass http://backend_{{ zone.id }};
        proxy_connect_timeout 3s;
        proxy_send_timeout 10s;
        proxy_read_timeout 10s;
    }
}
