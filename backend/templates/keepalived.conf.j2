! Configuration File for keepalived generated by LVS Nexus Control

global_defs {
   router_id {{ datacenter.router_id }}
}

vrrp_instance VI_1 {
    state {{ datacenter.state }}
    interface eth0
    virtual_router_id {{ datacenter.virtual_router_id }}
    priority {{ datacenter.priority }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass 1111
    }
    virtual_ipaddress {
        {%- for vip in vips %}
        {{ vip.virtual_ipaddress }}
        {%- endfor %}
    }
}

{% for vip in vips %}
virtual_server {{ vip.virtual_ipaddress }} {{ vip.port }} {
    delay_loop {{ vip.delay_loop }}
    lb_algo {{ vip.lb_algo }}
    lb_kind {{ vip.lb_kind }}
    persistence_timeout 50
    protocol TCP

    {%- if vip.servers %}
    {%- for server in vip.servers %}
    real_server {{ server.ip }} {{ server.port }} {
        weight {{ server.weight }}
        TCP_CHECK {
            connect_timeout 3
            nb_get_retry 3
            delay_before_retry 3
        }
    }
    {%- endfor %}
    {%- else %}
    ! No real servers configured for this VIP yet. (Pending Scale-Out)
    {%- endif %}
}
{% endfor %}
